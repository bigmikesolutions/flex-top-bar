{
  "name": "flex-top-bar",
  "version": "0.1.0",
  "description": "Flex Top Bar — a lightning-fast admin, live preview, multi-column layouts, animations, scheduling, and publish control. Turn visitors into customers before they scroll.",
  "author": "Big Mike Solutions",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package:zip": "npm run build && bash scripts/package-zip.sh",
    "package:top-bar": "npm run package:zip",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [],
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "less": "^4.2.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vue": "^3.5.31"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "@wordpress/i18n": "^6.15.0",
    "pinia": "^3.0.4"
  }
}
