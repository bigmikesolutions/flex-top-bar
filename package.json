{
  "name": "wordpress-plugins",
  "description": "WordPress plugins created by Big Mike Solutions.",
  "author": "BigMikeSolutions",
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.8",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "test": "npm test -w plugins/flex-top-bar",
    "test:ui": "npm run test:ui -w plugins/flex-top-bar",
    "test:e2e": "playwright test --workers=1 --timeout=60000",
    "test:e2e:single-bar": "playwright test --workers=1 e2e/top-bar-single.spec.ts",
    "test:e2e:scheduled": "playwright test --workers=1 e2e/top-bar-scheduled.spec.ts",
    "test:e2e:multi-bar": "playwright test --workers=1 e2e/top-bar-multi.spec.ts",
    "test:e2e:multi-column": "playwright test --workers=1 e2e/top-bar-multi-column.spec.ts",
    "test:e2e:multi-column-mobile": "playwright test --workers=1 e2e/top-bar-multi-column-mobile.spec.ts",
    "test:e2e:feature-flags": "playwright test --workers=1 e2e/feature-flags.spec.ts",
    "test:e2e:icons": "playwright test --workers=1 e2e/top-bar-icons.spec.ts",
    "test:e2e:publish": "playwright test --workers=1 e2e/top-bar-publish.spec.ts",
    "test:e2e:headed": "playwright test --workers=1 --headed",
    "test:e2e:ui": "playwright test --workers=1 --ui",
    "watch:styles": "npm run build:dist -w plugins/flex-top-bar -- --watch",
    "build:flex-top-bar": "npm run build -w plugins/flex-top-bar",
    "package:flex-top-bar": "npm run package:zip -w plugins/flex-top-bar",
    "package:flex-top-bar:freemius": "RELEASE_TARGET=freemius npm run package:zip -w plugins/flex-top-bar"
  },
  "workspaces": [
    "plugins/flex-top-bar"
  ],
  "dependencies": {
    "vite": "8.0.3",
    "vue": "^3.5.31"
  }
}
