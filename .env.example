# Copy to .env and adjust if needed
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=wordpress

# Set to 1 for debug output in local dev
WORDPRESS_DEBUG=1

# Automated install (skip browser setup wizard)
WORDPRESS_URL=http://localhost:8080
WORDPRESS_TITLE=Local WordPress
WORDPRESS_LOCALE=en_US
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin
WORDPRESS_ADMIN_EMAIL=admin@localhost.com

# Freemius (Docker Compose dev only)
FREEMIUS_PRODUCT_SLUG=flex-top-bar
FREEMIUS_SECRET_KEY=sk_test_replace_me

# Feature flags for local development
FF_MAX_BARS=5
FF_MAX_MESSAGES=5
FF_SCHEDULE=true